# ─────────────────────────────────────────────
#  Staging environment template
#
#  Copy to .env.staging (gitignored) and fill in real values.
#  In CI/CD pipelines inject these as environment variables directly —
#  no file needed when the platform supports secrets injection.
# ─────────────────────────────────────────────

NODE_ENV=staging
PORT=3000
LOG_LEVEL=info

# Staging frontend origin(s)
CORS_ORIGINS=https://staging.icgroup.example.com

SHUTDOWN_TIMEOUT_MS=10000

# ─────────────────────────────────────────────
#  PostgreSQL
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# ─────────────────────────────────────────────
#  Redis (min 16-char password enforced by Joi in staging/production)
# ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_AT_LEAST_16_CHARS

# ─────────────────────────────────────────────
#  JWT — generate via:
#  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
#  MinIO / S3
# ─────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_AT_LEAST_16_CHARS
MINIO_BUCKET_CONTENT=content-images
# MINIO_PUBLIC_URL=https://cdn.staging.icgroup.example.com

# ─────────────────────────────────────────────
#  Connection pool (scaled for staging)
# ─────────────────────────────────────────────
DB_POOL_MAX=10
DB_POOL_CONNECT_TIMEOUT_MS=3000
DB_POOL_IDLE_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=30000

# ─────────────────────────────────────────────
#  Rate limiting
# ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120
THROTTLE_LOGIN_TTL=60
THROTTLE_LOGIN_LIMIT=5

# Enable when behind nginx / ALB / reverse proxy
TRUST_PROXY=true
