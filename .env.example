# ─────────────────────────────────────────────
#  Application
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ─────────────────────────────────────────────
#  PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=icgroup
POSTGRES_USER=icgroup
POSTGRES_PASSWORD=changeme

# Prisma connection URL (auto-composed from above in prisma.config.ts)
DATABASE_URL=postgresql://icgroup:changeme@localhost:15432/icgroup

# ─────────────────────────────────────────────
#  Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD is required when Redis is configured with --requirepass (always in prod).
# For local dev via docker-compose the default matches the compose default.
REDIS_PASSWORD=changeme_redis

# ─────────────────────────────────────────────
#  JWT
# ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_64_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64_CHARS_MIN
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
#  MinIO / S3
# ─────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_CONTENT=content-images

# S3-compatible (for production — fill these and leave MINIO_* empty)
# S3_ENDPOINT=
# S3_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_CONTENT=

# ─────────────────────────────────────────────
#  Rate limiting
# ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120
THROTTLE_LOGIN_TTL=60
THROTTLE_LOGIN_LIMIT=5
