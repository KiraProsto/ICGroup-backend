# ─────────────────────────────────────────────
#  Production environment template
#
#  Copy to .env.production (gitignored) and fill in real values.
#  In CI/CD pipelines inject these as environment variables directly —
#  no file needed when the platform supports secrets injection (K8s Secrets,
#  AWS Parameter Store, Vault, etc.).
# ─────────────────────────────────────────────

NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Production frontend origin(s) — update to real domain
CORS_ORIGINS=https://icgroup.example.com

SHUTDOWN_TIMEOUT_MS=10000

# ─────────────────────────────────────────────
#  PostgreSQL
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# ─────────────────────────────────────────────
#  Redis (min 16-char password enforced by Joi in staging/production)
# ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_AT_LEAST_16_CHARS

# ─────────────────────────────────────────────
#  JWT — generate via:
#  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
#  MinIO / S3
# ─────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_AT_LEAST_16_CHARS
MINIO_BUCKET_CONTENT=content-images
# Set to your CDN or S3-compatible bucket URL for production object serving
# MINIO_PUBLIC_URL=https://cdn.icgroup.example.com

# ─────────────────────────────────────────────
#  Connection pool (tune for production workload)
# ─────────────────────────────────────────────
DB_POOL_MAX=20
DB_POOL_CONNECT_TIMEOUT_MS=3000
DB_POOL_IDLE_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=30000

# ─────────────────────────────────────────────
#  Rate limiting
# ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120
THROTTLE_LOGIN_TTL=60
THROTTLE_LOGIN_LIMIT=5

# Enable when behind nginx / ALB / reverse proxy (required in production)
TRUST_PROXY=true

# ─────────────────────────────────────────────
#  Swagger (API documentation)
# ─────────────────────────────────────────────
# Set to true to enable Swagger UI at /api/docs (protected by HTTP Basic Auth)
SWAGGER_ENABLED=false
# Required when SWAGGER_ENABLED=true in production/staging (min 4 / min 12 chars)
# SWAGGER_USER=
# SWAGGER_PASSWORD=
